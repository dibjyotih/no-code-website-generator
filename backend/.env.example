# AI Service
GEMINI_API_KEY=your_google_gemini_api_key_here

# Database (Optional - app will work without MongoDB)
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/webweaver

# MongoDB Atlas (Cloud - Free Tier Available):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/webweaver

# Authentication
JWT_SECRET=change_this_to_a_random_secret_string_in_production

# Server Configuration
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: Payment Integration (Stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Deployment Platform APIs
# VERCEL_TOKEN=...
# NETLIFY_TOKEN=...
# RAILWAY_TOKEN=...
